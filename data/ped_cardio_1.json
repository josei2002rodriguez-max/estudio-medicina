<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MedMaster - Estudio Dinámico</title>
    <style>
        :root {
            --primary: #4a90e2; --bg: #f5f7fa; --card: #ffffff;
            --text: #2c3e50; --accent: #27ae60; --error: #e74c3c;
            --secondary: #7f8c8d; --highlight: #ebf4ff;
        }
        body { font-family: 'Segoe UI', system-ui, sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 15px; line-height: 1.4; }
        .container { max-width: 800px; margin: 0 auto; }
        
        .view { display: none; animation: fadeIn 0.3s ease; }
        .view.active { display: block; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        h1 { text-align: center; color: var(--primary); margin-bottom: 10px; }
        .status-bar { text-align: center; font-size: 12px; color: var(--secondary); margin-bottom: 20px; }

        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 15px; margin-top: 15px; }
        .card { 
            background: var(--card); padding: 20px 10px; border-radius: 16px; text-align: center;
            cursor: pointer; border: 2px solid transparent; transition: 0.2s;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05); font-weight: 600;
        }
        .card:hover { transform: scale(1.02); border-color: var(--primary); }
        .card.selected { border-color: var(--accent); background: #f0fff4; }

        .setup-box { background: white; padding: 20px; border-radius: 16px; margin-top: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        .topic-item { display: flex; align-items: center; gap: 10px; padding: 10px 0; border-bottom: 1px solid #eee; }
        
        .btn { 
            display: block; width: 100%; padding: 16px; margin-top: 15px; border: none;
            border-radius: 12px; font-size: 16px; font-weight: bold; cursor: pointer; transition: 0.2s;
        }
        .btn-primary { background: var(--accent); color: white; }
        .btn-back { background: none; color: var(--secondary); border: 1px solid var(--secondary); margin-top: 20px; }

        /* Quiz UI */
        .q-header { display: flex; justify-content: space-between; font-size: 13px; color: var(--secondary); margin-bottom: 15px; }
        .option-btn { 
            display: block; width: 100%; padding: 16px; margin: 12px 0; border: 2px solid #edf2f7;
            border-radius: 12px; background: white; text-align: left; font-size: 15px; cursor: pointer;
            transition: 0.2s;
        }
        .option-btn.correct-show { border-color: var(--accent); background: #e6fffa; color: #155724; font-weight: bold; }
        .option-btn.wrong-show { border-color: var(--error); background: #fff5f5; color: #721c24; }
        .option-btn.inspecting { box-shadow: 0 0 0 3px var(--primary); transform: scale(1.01); }

        .hint-btn { background: none; border: none; color: #d69e2e; font-weight: bold; cursor: pointer; padding: 5px; margin-bottom: 10px; }
        .explanation { 
            margin-top: 15px; padding: 15px; border-radius: 12px; font-size: 14px; 
            border-left: 5px solid var(--primary); background: var(--highlight); display: none;
        }
    </style>
</head>
<body>

<div class="container">

    <div id="view-loading" class="view active">
        <h1>🩺 MedMaster</h1>
        <p style="text-align: center;">Cargando preguntas...</p>
    </div>
    
    <div id="view-internado" class="view">
        <h1>¿Qué Internado estudias?</h1>
        <div id="internado-grid" class="grid"></div>
        <div class="status-bar">Total preguntas cargadas: <span id="db-total">0</span></div>
    </div>

    <div id="view-setup" class="view">
        <h1 id="setup-title">Configurar Áreas</h1>
        <div id="area-grid" class="grid"></div>
        <div id="topic-config" class="setup-box" style="display:none;">
            <p><strong>Selecciona Tópicos:</strong></p>
            <div id="topic-list"></div>
            <div style="margin-top:20px;">
                <p>Preguntas disponibles: <strong id="total-count">0</strong></p>
                <input type="number" id="limit-input" placeholder="Cantidad (Vacio = todas)">
            </div>
            <button class="btn btn-primary" onclick="startQuiz()">Iniciar Sesión 🚀</button>
        </div>
        <button class="btn btn-back" onclick="showView('view-internado')">❮ Volver</button>
    </div>

    <div id="view-quiz" class="view">
        <div class="q-header"><span id="q-meta"></span><span id="q-progress"></span></div>
        <h2 id="q-text"></h2>
        <button class="hint-btn" onclick="toggleHint()">💡 Ver pista</button>
        <p id="q-hint" style="display:none; color: #744210; background: #fffaf0; padding: 10px; border-radius: 8px; font-size: 14px; margin-bottom: 15px;"></p>
        
        <div id="options-container"></div>
        
        <div id="explanation-box" class="explanation"></div>
        <button id="next-btn" class="btn btn-primary" style="display:none;" onclick="nextQuestion()">Siguiente Pregunta ➔</button>
    </div>

</div>

<script>
    /* CONFIGURACIÓN: Lista de tus archivos JSON */
    const archivosPreguntas = [
        'data/ped_cardio_1.json'
    ];

    let database = [];
    let currentInternado = "";
    let selectedAreas = new Set();
    let selectedTopics = new Set();
    let sessionQuestions = [];
    let currentIndex = 0;
    let isAnswered = false; // Nueva variable para controlar el estado

    async function cargarTodo() {
        showView('view-loading');
        for (const url of archivosPreguntas) {
            try {
                const res = await fetch(url);
                if (res.ok) {
                    const json = await res.json();
                    database = [...database, ...json];
                }
            } catch (e) { console.error("Error cargando: " + url); }
        }
        document.getElementById('db-total').innerText = database.length;
        renderInternados();
        showView(database.length > 0 ? 'view-internado' : 'view-loading');
    }

    function renderInternados() {
        const internados = [...new Set(database.map(q => q.internado))];
        const grid = document.getElementById('internado-grid');
        grid.innerHTML = "";
        internados.forEach(name => {
            const card = document.createElement('div');
            card.className = 'card';
            card.innerText = name;
            card.onclick = () => selectInternado(name);
            grid.appendChild(card);
        });
    }

    function selectInternado(name) {
        currentInternado = name;
        selectedAreas.clear();
        selectedTopics.clear();
        document.getElementById('setup-title').innerText = name;
        const areas = [...new Set(database.filter(q => q.internado === name).map(q => q.area))];
        const grid = document.getElementById('area-grid');
        grid.innerHTML = "";
        areas.forEach(area => {
            const card = document.createElement('div');
            card.className = 'card';
            card.innerText = area;
            card.onclick = () => toggleArea(area, card);
            grid.appendChild(card);
        });
        showView('view-setup');
    }

    function toggleArea(area, element) {
        if (selectedAreas.has(area)) { selectedAreas.delete(area); element.classList.remove('selected'); }
        else { selectedAreas.add(area); element.classList.add('selected'); }
        updateTopics();
    }

    function updateTopics() {
        const list = document.getElementById('topic-list');
        list.innerHTML = "";
        const config = document.getElementById('topic-config');
        if (selectedAreas.size === 0) { config.style.display = "none"; return; }
        config.style.display = "block";
        const topics = [...new Set(database.filter(q => q.internado === currentInternado && selectedAreas.has(q.area)).map(q => q.topic))];
        topics.forEach(t => {
            const div = document.createElement('div');
            div.className = 'topic-item';
            div.innerHTML = `<input type="checkbox" checked id="c-${t}" onchange="toggleTopic('${t}')"> <label for="c-${t}">${t}</label>`;
            list.appendChild(div);
            selectedTopics.add(t);
        });
        updateCount();
    }

    function toggleTopic(t) {
        if (selectedTopics.has(t)) selectedTopics.delete(t);
        else selectedTopics.add(t);
        updateCount();
    }

    function updateCount() {
        const count = database.filter(q => q.internado === currentInternado && selectedAreas.has(q.area) && selectedTopics.has(q.topic)).length;
        document.getElementById('total-count').innerText = count;
    }

    function startQuiz() {
        let pool = database.filter(q => q.internado === currentInternado && selectedAreas.has(q.area) && selectedTopics.has(q.topic));
        pool.sort(() => Math.random() - 0.5);
        const limit = document.getElementById('limit-input').value;
        if (limit) pool = pool.slice(0, parseInt(limit));
        if (pool.length === 0) return alert("Selecciona temas.");
        sessionQuestions = pool;
        currentIndex = 0;
        showView('view-quiz');
        renderQuestion();
    }

    function renderQuestion() {
        isAnswered = false; // Resetear estado para nueva pregunta
        const q = sessionQuestions[currentIndex];
        document.getElementById('q-meta').innerText = `${q.area} • ${q.topic}`;
        document.getElementById('q-progress').innerText = `${currentIndex + 1} / ${sessionQuestions.length}`;
        document.getElementById('q-text').innerText = q.text;
        document.getElementById('q-hint').innerText = q.hint || "Sin pistas.";
        document.getElementById('q-hint').style.display = "none";
        document.getElementById('explanation-box').style.display = "none";
        document.getElementById('next-btn').style.display = "none";

        const container = document.getElementById('options-container');
        container.innerHTML = "";

        q.options.forEach((opt, idx) => {
            const b = document.createElement('button');
            b.className = 'option-btn';
            b.innerText = opt.text;
            b.onclick = () => handleOptionClick(b, opt, q);
            container.appendChild(b);
        });
    }

    function handleOptionClick(button, option, question) {
        const container = document.getElementById('options-container');
        const expBox = document.getElementById('explanation-box');

        // Primera vez que responde: Calificar
        if (!isAnswered) {
            isAnswered = true;
            document.getElementById('next-btn').style.display = "block";
            
            // Marcar todas las opciones visualmente
            const buttons = container.querySelectorAll('.option-btn');
            question.options.forEach((opt, i) => {
                if (opt.isCorrect) buttons[i].classList.add('correct-show');
                else if (buttons[i] === button) buttons[i].classList.add('wrong-show');
            });
        }

        // Siempre: Mostrar explicación de la opción clickeada
        container.querySelectorAll('.option-btn').forEach(btn => btn.classList.remove('inspecting'));
        button.classList.add('inspecting');
        
        expBox.style.display = "block";
        expBox.style.borderLeftColor = option.isCorrect ? "var(--accent)" : "var(--error)";
        expBox.innerHTML = `<strong>Análisis de la opción:</strong><br>${option.explanation}`;
    }

    function toggleHint() {
        const h = document.getElementById('q-hint');
        h.style.display = h.style.display === "none" ? "block" : "none";
    }

    function nextQuestion() {
        currentIndex++;
        if (currentIndex < sessionQuestions.length) renderQuestion();
        else { alert("¡Sesión terminada!"); showView('view-internado'); }
    }

    function showView(id) {
        document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
        document.getElementById(id).classList.add('active');
    }

    window.onload = cargarTodo;
</script>
</body>
</html>
